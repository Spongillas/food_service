# Ключ OpenRouter (https://openrouter.ai/keys) — обязателен для реального ИИ-поиска.
# Если оставить пустым, сервис работает в демо-режиме на заглушках.
OPENROUTER_API_KEY=

# Модель OpenRouter. Суффикс ":online" включает веб-поиск (плагин на базе Exa),
# то есть модель сама гуглит и читает страницы перед ответом.
OPENROUTER_MODEL=openai/gpt-4o-mini:online

# Необязательно: показываются в заголовках запроса к OpenRouter (для рейтингов на openrouter.ai)
APP_URL=http://localhost:8000
APP_NAME=Food Supplier Finder
